# GEMINI_API_KEY: Optional. Required only if you wire Gemini AI features.
# AI Studio can inject this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# Store locator uses free OpenStreetMap + Nominatim + Overpass — no Maps API key needed.
