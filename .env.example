# GEMINI_API_KEY: Optional. Required only if you wire Gemini AI features.
# AI Studio can inject this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_GOOGLE_MAPS_API_KEY: Client-side Maps JavaScript API key (visible in the browser).
# Enable "Maps JavaScript API" + "Places API" in Google Cloud, then restrict the key by HTTP referrer:
#   https://rohans16-cmyk.github.io/*
#   http://localhost:3000/*
# Also enable Geocoding (used via the Maps JS Geocoder for zip/city search).
# For GitHub Pages, add the same value as a repo secret named VITE_GOOGLE_MAPS_API_KEY.
VITE_GOOGLE_MAPS_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"
